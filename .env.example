# Copy to ".env" and fill in. NEVER commit your real key.

# Server-side only — used by the /api routes to call Claude. Not exposed to the app.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: point the mobile app at your running dev server so it can reach the
# AI /api routes on a real device (e.g. http://192.168.1.20:8081).
# Leave unset to use the built-in sample lessons (fully playable offline).
# EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:8081
